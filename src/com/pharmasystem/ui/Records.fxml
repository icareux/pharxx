<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmasystem.ui.RecordsController"
      styleClass="root"
      stylesheets="@pharx.css"
      prefWidth="760" prefHeight="520"
      style="-fx-background-color: #F4F6FA;">

    <!-- Header bar -->
    <HBox style="-fx-background-color: #0A1628; -fx-padding: 20 24 20 24;" alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="2">
            <Label text="Sales Records" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Label text="Transaction history" style="-fx-text-fill: #475569; -fx-font-size: 11px;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕  Close" styleClass="btn-secondary"
                style="-fx-pref-height: 34px; -fx-font-size: 12px;"
                onAction="#closeWindow"/>
    </HBox>

    <!-- Filters -->
    <HBox style="-fx-padding: 16 20 12 20; -fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT" spacing="12">
        <Label text="SCOPE" styleClass="field-label"/>
        <ChoiceBox fx:id="scopeChoice" styleClass="choice-box" style="-fx-pref-width: 150;"/>
        <Label text="SORT" styleClass="field-label"/>
        <ChoiceBox fx:id="sortChoice" styleClass="choice-box" style="-fx-pref-width: 150;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="↺  Refresh" styleClass="btn-secondary"
                style="-fx-pref-height: 34px; -fx-font-size: 12px;"
                onAction="#refreshRecords"/>
    </HBox>

    <!-- Table -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 16 20 20 20;" spacing="0">
        <VBox styleClass="card" VBox.vgrow="ALWAYS">
            <TableView fx:id="recordsTable" VBox.vgrow="ALWAYS"
                       styleClass="table-view"
                       style="-fx-background-color: transparent;">
                <columns>
                    <TableColumn fx:id="saleIdCol"      text="SALE ID"      prefWidth="260"/>
                    <TableColumn fx:id="saleDateCol"    text="DATE &amp; TIME" prefWidth="180"/>
                    <TableColumn fx:id="totalAmountCol" text="TOTAL (₱)"    prefWidth="130"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>

</VBox>
